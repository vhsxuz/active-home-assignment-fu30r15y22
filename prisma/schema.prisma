// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model NFT {
  id            String   @id @default(uuid())
  name          String
  description   String?
  image         String?
  mintedAt      DateTime @default(now())
  ownerAddress  String?
}
